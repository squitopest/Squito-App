default_platform(:ios)

platform :ios do
  desc "Build the iOS app for TestFlight / App Store"
  lane :build_and_export do

    # Apply manual signing ONLY to the App target (not SPM packages)
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "App.xcodeproj",
      team_id: "4367ZCH572",
      bundle_identifier: "com.squito.app",
      profile_name: "Squito Pest Control App",
      code_sign_identity: "Apple Distribution",
      targets: ["App"]
    )

    # Build the app using gym
    gym(
      project: "App.xcodeproj",
      scheme: "App",
      export_method: "app-store",
      export_team_id: "4367ZCH572",
      xcargs: "DEVELOPMENT_TEAM=4367ZCH572",
      clean: true,
      output_directory: "./build",
      output_name: "SquitoApp.ipa",
      export_options: {
        provisioningProfiles: {
          "com.squito.app" => "Squito Pest Control App"
        }
      }
    )
  end
end
